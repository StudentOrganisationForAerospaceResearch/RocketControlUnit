    {
        "id": "ae9cb509b69ef705",
        "type": "function",
        "z": "f990588fcb779318",
        "name": "Save Data",
        "func": "const array=msg.payload\nconst data=array[array.length-1]\n// Save all Data to global variables\nglobal.set(\"time\",data.time)\nglobal.set(\"nos1Temp\",data.nos1Temp)\nglobal.set(\"nos2Temp\",data.nos2Temp)\nglobal.set(\"nos1LoadCell\",data.nos1LoadCell)\nglobal.set(\"nos2LoadCell\",data.nos2LoadCell)\nglobal.set(\"ac1\", data.ac1)\nglobal.set(\"ac2\", data.ac2)\nglobal.set(\"p1\",data.p1)\nglobal.set(\"p2\",data.p2)\nglobal.set(\"p3\",data.p3)\nglobal.set(\"p4\",data.p4)\nglobal.set(\"AirTemp\",data.AirTemp)\nglobal.set(\"LoadCell\",data.LoadCell)\nglobal.set(\"Continuity\",data.Continuity)\n\n\n\n//msg.payload = array[4].p1\nreturn [{ payload: data.time }, { payload: data.nos1Temp, topic: \"NOS1\" }, \n    { payload: data.nos2Temp, topic: \"NOS2\"},\n    { payload: data.nos1LoadCell }, { payload: data.nos2LoadCell},\n    { payload: data.ac1, topic: \"AC1\" }, { payload: data.ac2, topic: \"AC2\" },\n    { payload: data.p1, topic: \"Pressure 1\" }, { payload: data.p2, topic: \"Pressure 2\" },\n    { payload: data.p3, topic: \"Pressure 3\" }, { payload: data.p4, topic: \"Pressure 4\" },\n    { payload: data.AirTemp }, { payload: data.LoadCell},\n    { payload: data.Continuity}];",
        "outputs": 14,
        "noerr": 0,
