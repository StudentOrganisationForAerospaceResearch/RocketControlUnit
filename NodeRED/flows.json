    {
        "id": "5158764becc335a7",
        "type": "function",
        "z": "f990588fcb779318",
        "name": "Heartbeat",
        "func": "const heartbeat=global.get(\"Continuity\")\nconst dt=global.get(\"heartbeatTimeout\")\nif (heartbeat-global.get(\"Continuity-1\")!=0) {\n    if (dt!=0){\n        global.set(\"heartbeatTimeout\",0)\n    }\n    global.set(\"Continuity-1\",heartbeat)\n    msg.payload=\"Alive\"\n    msg.color=\"green\"\n}\nelse{\n    if (dt<5){\n        global.set(\"heartbeatTimeout\",dt+1)\n        msg.payload=\"Issue\"\n        msg.color=\"yellow\"\n    }\n    else{\n        msg.payload=\"Connection Lost\"\n        msg.color=\"red\"\n    }\n    \n    //node.warn(\"Heartbeat is dead\");\n\n}\n\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "// Code added here will be run once\n// whenever the node is started.\nglobal.set(\"heartbeatTimeout\",0)\nglobal.set(\"Continuity-1\",0)",
