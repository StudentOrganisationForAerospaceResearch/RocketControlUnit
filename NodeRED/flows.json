        "id": "f7ad813bccc7ba04",
        "type": "function",
        "z": "f990588fcb779318",
        "name": "Status",
        "func": "const status=global.get(\"status\")\n\nswitch (status) {\n    case \"Armed\":\n        msg.color=\"green\"\n        msg.payload=\"Armed\"\n        break\n    case \"Prelaunch\":\n        msg.color=\"green\"\n        msg.payload=\"Prelaunch\"\n        break\n    case \"Burn\":\n        msg.color=\"yellow\"\n        msg.payload=\"Burn\"\n        break\n    case \"Coast\":\n        msg.color=\"violet\"\n        msg.payload=\"Coasting\"\n        break\n    case \"Aborted\":\n        msg.color=\"red\"\n        msg.payload=\"Aborted\"\n        break  \n}\n\nreturn msg;",
